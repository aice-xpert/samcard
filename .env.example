# =============================================================================
# SAMCARD - Environment Variables
# =============================================================================


# Database
DATABASE_URL="postgresql://user:password@localhost:5432/samcard?schema=public"

# For MySQL
# DATABASE_URL="mysql://user:password@localhost:3306/samcard"

# For SQLite (development only)
# DATABASE_URL="file:./dev.db"

# Authentication (NextAuth.js)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-super-secret-key-change-in-production"

# Backend API URL (set this in deployment)
BACKEND_URL="http://localhost:5001"
NEXT_PUBLIC_BACKEND_URL="http://localhost:5001"

# OAuth Providers (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Stripe (for billing)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# File Storage (for image uploads)
STORAGE_BUCKET=""
STORAGE_REGION=""
STORAGE_ACCESS_KEY=""
STORAGE_SECRET_KEY=""

# Analytics
ANALYTICS_API_KEY=""
NEXT_PUBLIC_ANALYTICS_ID=""

# Email (for notifications)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
EMAIL_FROM="noreply@samcard.app"

# CDN (for serving images)
NEXT_PUBLIC_CDN_URL=""

# QR Code API
QR_API_URL=""

# NFC Writing Service
NFC_SERVICE_URL=""

# Rate Limiting
RATE_LIMIT_MAX_REQUESTS="100"
RATE_LIMIT_WINDOW_MS="60000"
