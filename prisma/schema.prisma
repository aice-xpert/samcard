// =============================================================================
// SAMCARD - Digital Business Card Platform
// Complete Database Schema - Optimized for Supabase PostgreSQL
// =============================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch", "fullTextIndex"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// ENUMS
// =============================================================================

enum UserRole {
  ADMIN
  USER
  GUEST
}

enum AccountProvider {
  GOOGLE
  GITHUB
  EMAIL
  LINKEDIN
  APPLE
  TWITTER
  FACEBOOK
}

enum Theme {
  DARK
  LIGHT
  SYSTEM
}

enum CardStatus {
  ACTIVE
  INACTIVE
  DRAFT
  ARCHIVED
  SUSPENDED
}

enum CardType {
  NFC
  QR
  LINK
  HYBRID
}

enum LogoPosition {
  TOP_LEFT
  TOP_RIGHT
  BELOW_PHOTO
  BELOW_NAME
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  SUSPENDED
  TRIALING
}

enum PlanTier {
  FREE
  STARTER
  PROFESSIONAL
  BUSINESS
  ENTERPRISE
}

enum LeadSource {
  NFC
  QR
  LINK_CLICK
  DIRECT
  SEARCH
  REFERRAL
  SOCIAL
  ORGANIC
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CONVERTED
  LOST
  ARCHIVED
}

enum NotificationType {
  LEAD
  TAP
  SCAN
  MESSAGE
  SYSTEM
  BILLING
  PROMO
  SECURITY
  CARD
  ANALYTICS
}

enum DeviceType {
  IOS
  ANDROID
  WEB
  NFC_READER
  QR_SCANNER
  UNKNOWN
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  EXPORT
  SHARE
  VIEW
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum GoalType {
  MONTHLY_TAPS
  WEEKLY_VIEWS
  MONTHLY_LEADS
  CONVERSION_RATE
  CUSTOM
}

enum SocialPlatform {
  LINKEDIN
  INSTAGRAM
  FACEBOOK
  TWITTER
  YOUTUBE
  TIKTOK
  GITHUB
  DISCORD
  YELP
  SNAPCHAT
  PINTEREST
  REDDIT
  MEDIUM
  BEHANCE
  THREADS
  WHATSAPP
  TELEGRAM
  CUSTOM
}

enum ExtraSectionType {
  BUTTON
  VIDEO
  AUDIO
  PDF
  IMAGE_TEXT
  TEAM
  CUSTOMER
  PRODUCTS
  SERVICES
  HOURS
  GALLERY
  PORTFOLIO
  TESTIMONIALS
  AMENITIES
  EMBED
  MAP
}

enum QRShapeType {
  SQUARE
  ROUNDED
  CIRCLE
  HEXAGON
  KITE
  STAR
  DIAMOND
  BEVEL
  LETTER
}

enum QRDotShape {
  SQUARE
  ROUNDED_TAG
  ROUNDED
  DOT
  TINY_DOT
  DIAMOND
  STAR
  CROSS
  PLUS
  HEXAGON
  LEAF
  BARS_H
  BARS_V
  MOSAIC
  WAVE
  DNA
  ARROW_R
  ARROW_L
  KITE
  ROUNDED_SQUARE
}

enum QREyeFrameStyle {
  SQUARE
  ROUNDED
  CIRCLE
  DOT_OUTLINE
  ROUND_OUTER
  THICK
  DASHED
  DOUBLE
  OCTAGON
  GAP
}

enum QREyeBallStyle {
  CIRCLE
  SQUARE
  ROUNDED
  DIAMOND
  HEXAGON
  STAR
  SQUIRCLE
  KITE
  LEAF
  CROSS
  RING
  DOT_SQ
}

enum WallpaperType {
  SOLID
  GRADIENT
  RADIAL
}

enum ShadowIntensity {
  NONE
  SOFT
  MEDIUM
  STRONG
}

enum FontFamily {
  INTER
  SORA
  DM_SANS
  POPPINS
  RALEEWAY
  PLAYFAIR_DISPLAY
  FIRA_CODE
  SYSTEM
}

enum PaymentCardBrand {
  VISA
  MASTERCARD
  AMEX
  DISCOVER
  JCB
  UNIONPAY
}

// =============================================================================
// USER & AUTHENTICATION
// =============================================================================

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  emailVerified     Boolean   @default(false)
  passwordHash      String?
  name              String?
  phone             String?
  avatar            String?
  role              UserRole  @default(USER)

  // Preferences
  timezone          String    @default("UTC")
  language          String    @default("en")
  theme             Theme     @default(DARK)
  compactMode       Boolean   @default(false)

  // Subscription
  subscriptionId    String?
  planTier          PlanTier  @default(FREE)
  subscriptionStatus SubscriptionStatus @default(ACTIVE)
  subscriptionEndsAt DateTime?

  // Plan Limits
  maxCards          Int       @default(1)
  maxTaps           Int       @default(500)
  maxStorageMb      Int       @default(256)
  maxLeads          Int       @default(100)

  // Statistics (aggregated)
  totalCards        Int       @default(0)
  totalTaps         Int       @default(0)
  totalViews        Int       @default(0)
  totalLeads        Int       @default(0)
  totalOrders       Int       @default(0)
  totalSpent        Float     @default(0)

  // Privacy Settings
  profilePublic     Boolean   @default(true)
  showEmail         Boolean   @default(true)
  showPhone         Boolean   @default(true)
  analyticsOptIn    Boolean   @default(true)

  // Timestamps
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  lastLoginAt       DateTime?
  emailVerifiedAt   DateTime?
  deletedAt         DateTime?

  // Relations - One-to-Many
  accounts            Account[]
  sessions            Session[]
  businessProfiles    BusinessProfile[]
  cards               Card[]
  orders              Order[]
  invoices            Invoice[]
  notifications       Notification[]
  auditLogs           AuditLog[]
  leads               Lead[]
  goals               Goal[]
  connectedAccounts   UserConnectedAccount[]
  paymentMethods      PaymentMethod[]
  webhookConfigs      Webhook[]
  analyticsEvents     AnalyticsEvent[]
  nfcCards            NfcCard[]
  cardDesigns         CardDesign[]
  qrTemplates         QRTemplate[]

  // Relation - One-to-One (enforced via unique constraint on DashboardStats)
  dashboardStats      DashboardStats?

  @@index([email])
  @@index([planTier])
  @@index([subscriptionStatus])
  @@index([role])
  @@index([createdAt])
}

model Account {
  id                 String          @id @default(cuid())
  userId             String
  provider           AccountProvider
  providerAccountId String
  accessToken       String?
  refreshToken      String?
  expiresAt         DateTime?
  tokenType         String?
  scope             String?
  idToken           String?
  sessionState      String?

  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String    @id @default(cuid())
  userId       String
  token        String    @unique
  device       String?
  deviceType   DeviceType @default(WEB)
  browser      String?
  os           String?
  ipAddress    String?
  location     String?
  isCurrent    Boolean   @default(false)
  userAgent    String?

  expiresAt    DateTime
  createdAt   DateTime  @default(now())
  lastActiveAt DateTime @default(now())

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([isCurrent])
}

// =============================================================================
// BUSINESS PROFILE
// =============================================================================

model BusinessProfile {
  id                String    @id @default(cuid())
  userId            String

  // Basic Info
  name              String
  slug              String    @unique
  title             String?
  company           String?
  tagline           String?

  // Cover & Media
  profileImageUrl   String?
  coverImageUrl     String?
  brandLogoUrl      String?
  logoPosition      LogoPosition @default(TOP_LEFT)

  // Contact Information
  primaryEmail      String?
  secondaryEmail    String?
  primaryPhone      String?
  secondaryPhone    String?
  website           String?
  address           String?
  city              String?
  state             String?
  country           String?
  postalCode        String?
  latitude          Float?
  longitude         Float?

  // Professional Details
  industry          String?
  department        String?
  jobLevel          String?
  yearFounded       Int?
  companySize       String?

  // Appointment Booking
  appointmentEnabled Boolean  @default(false)
  appointmentUrl     String?
  appointmentLabel   String? @default("Book a Call")

  // Contact Collection
  collectContactsEnabled Boolean @default(true)
  collectNotesEnabled    Boolean @default(false)
  contactFormLabel      String? @default("Add to Contact")

  // Section Content
  headingText       String?
  headingBodyText   String?
  contactUsHeading  String?
  contactUsBodyText String?

  // SEO & Sharing
  metaTitle         String?
  metaDescription   String?
  ogImage           String?
  shareUrl          String?

  // Custom CSS/JS
  customCss         String?
  customJs          String?

  // Profile Completion (0-100)
  completionScore   Int      @default(0)
  engagementScore   Int      @default(0)

  // Timestamps
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  publishedAt       DateTime?
  deletedAt         DateTime?

  // Relations - One-to-Many
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  cards             Card[]
  socialLinks       SocialLink[]
  customLinks       CustomLink[]
  extraSections     ExtraSection[]
  leads             Lead[]

  @@index([userId])
  @@index([slug])
  @@index([industry])
  @@index([createdAt])
}

model SocialLink {
  id                  String         @id @default(cuid())
  businessProfileId    String

  platform            SocialPlatform
  handle              String
  url                 String?
  label               String?
  icon                String?

  displayOrder        Int            @default(0)
  enabled             Boolean        @default(true)

  // Statistics
  totalClicks         Int            @default(0)
  uniqueClicks        Int            @default(0)

  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  businessProfile      BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)
  linkClicks          LinkClick[]

  // Each platform can only have ONE link per business profile
  @@unique([businessProfileId, platform])
  @@index([businessProfileId])
}

model CustomLink {
  id                  String         @id @default(cuid())
  businessProfileId    String

  label               String
  url                 String
  icon                String?
  color               String?

  displayOrder        Int            @default(0)
  enabled             Boolean        @default(true)
  clickTracking       Boolean        @default(true)

  // Statistics
  totalClicks         Int            @default(0)
  uniqueClicks        Int            @default(0)
  lastClickedAt        DateTime?

  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  businessProfile      BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)
  linkClicks          LinkClick[]

  @@index([businessProfileId])
}

model ExtraSection {
  id                  String           @id @default(cuid())
  businessProfileId    String
  type                ExtraSectionType

  label               String
  displayOrder        Int              @default(0)
  enabled             Boolean          @default(true)
  expanded            Boolean          @default(true)
  data                Json             @default("{}")

  showOnCard          Boolean          @default(true)
  showOnPreview       Boolean          @default(true)

  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  businessProfile      BusinessProfile  @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)

  @@index([businessProfileId])
  @@index([type])
}

// =============================================================================
// DIGITAL BUSINESS CARDS
// =============================================================================

model Card {
  id                  String      @id @default(cuid())
  userId              String
  businessProfileId   String

  // Card Identity
  name                String
  cardType            CardType    @default(QR)
  status              CardStatus  @default(DRAFT)

  // URLs & Sharing - UNIQUE constraints for data integrity
  slug                String      @unique
  shareUrl            String      @unique
  shortUrl            String?     @unique

  // Content Overrides
  headingText         String?
  headingBodyText     String?

  // NFC Configuration - UNIQUE uid constraint
  nfcUid              String?     @unique
  nfcEnabled          Boolean     @default(false)
  nfcWriteCount       Int         @default(0)
  nfcLastWrittenAt    DateTime?

  // QR Configuration
  qrEnabled           Boolean     @default(true)
  qrConfig            Json?
  qrMatrix            Bytes?
  qrScanCount         Int         @default(0)
  qrLastScannedAt     DateTime?
  qrShape             QRShapeType @default(ROUNDED)

  // Design
  designId            String?
  themeOverride       Json?

  // Section Visibility
  showProfile         Boolean     @default(true)
  showHeading         Boolean     @default(true)
  showContact         Boolean     @default(true)
  showSocial          Boolean     @default(true)
  showLinks           Boolean     @default(true)
  showAppointment     Boolean     @default(true)
  showBusinessDetails Boolean     @default(true)
  showExtraSections   Boolean     @default(true)

  // Appearance
  backgroundColor     String      @default("#000000")
  accentColor         String      @default("#008001")
  accentLight         String      @default("#49B618")
  textColor           String      @default("#FFFFFF")
  cardColor           String      @default("#0a0a0a")
  cardRadius          Int         @default(16)
  fontFamily          FontFamily  @default(INTER)
  nameFontSize        Int         @default(24)
  bodyFontSize        Int         @default(14)
  boldHeadings        Boolean     @default(false)

  // Phone Background
  phoneBgType         WallpaperType   @default(SOLID)
  phoneBgPreset       String?
  phoneBgColor1       String      @default("#000000")
  phoneBgColor2       String      @default("#0a0a0a")
  phoneBgAngle        Int         @default(180)
  shadowIntensity     ShadowIntensity @default(MEDIUM)
  glowEffect          Boolean     @default(false)

  // Media
  thumbnailUrl        String?

  // SEO
  metaTitle           String?
  metaDescription     String?
  ogImage             String?

  // Statistics
  totalViews          Int         @default(0)
  totalTaps           Int         @default(0)
  totalScans          Int         @default(0)
  totalSaves          Int         @default(0)
  totalShares         Int         @default(0)
  uniqueVisitors      Int         @default(0)
  totalLinkClicks     Int         @default(0)

  // Weekly Stats
  thisWeekViews       Int         @default(0)
  thisWeekTaps        Int         @default(0)

  // Goals
  monthlyTapGoal      Int?
  monthlyViewGoal     Int?

  // Completion Score
  completionScore     Int         @default(0)

  // Timestamps
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  publishedAt         DateTime?
  lastSharedAt        DateTime?
  deletedAt           DateTime?

  // Relations - Many-to-One
  user                User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessProfile     BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)
  design              CardDesign? @relation(fields: [designId], references: [id])

  // Relations - One-to-Many
  interactions        CardInteraction[]
  shares              CardShare[]
  analytics           CardAnalytics[]
  leads               Lead[]
  linkClicks          LinkClick[]
  nfcCard             NfcCard?

  @@index([userId])
  @@index([businessProfileId])
  @@index([status])
  @@index([slug])
  @@index([nfcUid])
  @@index([createdAt])
  @@index([userId, status])
  @@index([businessProfileId, status])
}

model CardDesign {
  id                  String    @id @default(cuid())
  userId              String?

  name                String
  description         String?
  isPreset            Boolean   @default(false)
  isPublic            Boolean   @default(false)

  // Colors
  accentColor         String    @default("#008001")
  accentLight         String    @default("#49B618")
  backgroundColor     String    @default("#000000")
  cardColor           String    @default("#0a0a0a")
  textPrimary         String    @default("#FFFFFF")
  textMuted          String    @default("#A0A0A0")

  // Typography
  fontFamily          FontFamily @default(INTER)
  nameFontSize        Int       @default(24)
  bodyFontSize        Int       @default(14)
  boldHeadings        Boolean   @default(false)

  // Card Styling
  cardRadius          Int       @default(16)
  shadowIntensity     ShadowIntensity @default(MEDIUM)
  glowEffect          Boolean   @default(false)

  // Phone Background
  phoneBgType         WallpaperType @default(SOLID)
  phoneBgPreset       String?
  phoneBgColor1       String    @default("#000000")
  phoneBgColor2       String    @default("#0a0a0a")
  phoneBgAngle        Int       @default(180)

  // Preview
  thumbnailUrl        String?

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // Relation - One-to-Many (nullable userId for system presets)
  user                User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cards               Card[]

  @@index([userId])
  @@index([isPreset])
  @@index([isPublic])
}

model ColorPalette {
  id        Int      @id @default(autoincrement())

  name      String   @unique
  emoji     String?

  // Colors
  accent    String
  accentLight String
  bg        String
  card      String
  textPrimary String
  textMuted String

  wallpaper String?
  isPreset  Boolean @default(false)
  displayOrder Int  @default(0)

  createdAt DateTime @default(now())
}

model WallpaperPreset {
  id        Int      @id @default(autoincrement())

  name      String   @unique
  style     String
  color1    String
  color2    String?
  angle     Int?

  thumb     String?
  isPreset  Boolean @default(false)
  displayOrder Int  @default(0)

  createdAt DateTime @default(now())
}

// =============================================================================
// QR CODE CONFIGURATION
// =============================================================================

model QRTemplate {
  id                  String       @id @default(cuid())
  userId              String?

  name                String
  description         String?
  isPreset            Boolean      @default(false)
  isPublic            Boolean      @default(false)

  // Shape
  shapeId             QRShapeType  @default(ROUNDED)

  // Dot Configuration
  dotShape            QRDotShape   @default(ROUNDED)
  bodyScale           Float        @default(0.8)

  // Eye Configuration
  eyeFrameStyle       QREyeFrameStyle @default(ROUNDED)
  eyeBallStyle        QREyeBallStyle  @default(CIRCLE)

  // Colors
  fgColor             String       @default("#FFFFFF")
  bgColor             String       @default("#000000")

  // Accent Colors
  accentFgEnabled     Boolean      @default(false)
  accentFg            String?
  accentBgEnabled     Boolean      @default(false)
  accentBg            String?

  // Stroke
  strokeEnabled       Boolean      @default(false)
  strokeColor         String       @default("#FFFFFF")

  // Gradient
  gradEnabled         Boolean      @default(false)
  gradStops           Json?
  gradAngle           Int          @default(180)

  // Logo
  logoId              String?
  customLogoUrl       String?

  // Sticker
  stickerId           String?
  stickerData         Json?

  // Decoration
  decorateImageUrl    String?
  decoratePosition    String?
  decorateComposite   Bytes?

  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  user                User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([isPreset])
}

model QRPresetLogo {
  id        Int      @id @default(autoincrement())

  name      String
  category  String
  icon      String
  isPreset  Boolean  @default(true)
  displayOrder Int   @default(0)

  createdAt DateTime @default(now())

  @@index([category])
}

model QRSticker {
  id        Int      @id @default(autoincrement())

  name      String
  category  String
  style     String
  defaultWidth Int   @default(60)
  defaultPosition String @default("bottom-right")
  defaultColor String?
  defaultOutline String?
  isPreset  Boolean @default(true)
  displayOrder Int  @default(0)

  createdAt DateTime @default(now())

  @@index([category])
}

// =============================================================================
// CARD INTERACTIONS & ANALYTICS
// =============================================================================

model CardInteraction {
  id           String      @id @default(cuid())
  cardId       String

  type         String
  visitorId    String?
  fingerprint  String?
  ipAddress    String?
  userAgent    String?
  deviceType   DeviceType  @default(UNKNOWN)
  browser      String?
  os           String?

  // Location
  city         String?
  country      String?
  countryCode  String?
  region       String?
  latitude     Float?
  longitude    Float?

  // Attribution
  referrer     String?
  utmSource    String?
  utmMedium    String?
  utmCampaign  String?
  utmContent   String?

  // For link clicks
  linkId       String?
  linkLabel    String?

  // Engagement
  durationSeconds Int?
  scrollDepth  Int?
  actionsPerformed Json?

  // Device Info
  screenWidth  Int?
  screenHeight Int?
  isMobile     Boolean?
  isTablet     Boolean?

  createdAt    DateTime    @default(now())

  card         Card        @relation(fields: [cardId], references: [id], onDelete: Cascade)

  // Prevents duplicate interactions from same visitor on same card at same second
  @@unique([cardId, visitorId, type, createdAt])
  @@index([cardId])
  @@index([type])
  @@index([createdAt])
  @@index([visitorId])
  @@index([country])
  @@index([deviceType])
}

model CardShare {
  id        String   @id @default(cuid())
  cardId    String

  method    String
  recipientEmail String?
  recipientPhone String?
  recipientName String?
  sharedUrl String
  sharedByIp String?
  sharedByVisitorId String?

  wasOpened Boolean @default(false)
  openedAt  DateTime?
  wasEngaged Boolean @default(false)
  engagedAt DateTime?
  wasConverted Boolean @default(false)
  convertedAt DateTime?

  createdAt DateTime @default(now())

  card      Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId])
  @@index([method])
  @@index([createdAt])
}

model CardAnalytics {
  id        String   @id @default(cuid())
  cardId    String
  date      DateTime @db.Date
  hour      Int?

  // Basic Metrics
  views           Int @default(0)
  uniqueViews     Int @default(0)
  taps            Int @default(0)
  uniqueTaps      Int @default(0)
  scans           Int @default(0)
  uniqueScans     Int @default(0)
  saves           Int @default(0)
  shares          Int @default(0)
  linkClicks      Int @default(0)

  // Traffic Sources
  nfcTraffic      Int @default(0)
  qrTraffic       Int @default(0)
  linkTraffic     Int @default(0)
  directTraffic   Int @default(0)
  searchTraffic   Int @default(0)
  socialTraffic   Int @default(0)
  referralTraffic Int @default(0)

  // Device Breakdown
  deviceBreakdown Json?
  browserBreakdown Json?
  osBreakdown     Json?

  // Geographic
  countryBreakdown Json?
  cityBreakdown   Json?

  // Engagement
  avgDurationSeconds Float?
  maxDurationSeconds Int?
  avgScrollDepth     Float?
  totalSessions      Int @default(0)

  // Conversion
  leadsGenerated   Int @default(0)
  conversionRate   Float?

  // Link Performance
  linkClickBreakdown Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  card      Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)

  // One record per card per date (and hour if specified)
  @@unique([cardId, date, hour])
  @@index([cardId])
  @@index([date])
}

// =============================================================================
// LINK CLICK TRACKING
// =============================================================================

model LinkClick {
  id           String     @id @default(cuid())

  // Card context - ALWAYS required for link tracking
  cardId       String

  // EXCLUSIVE relationship - Either socialLinkId OR customLinkId (not both, not neither)
  // Enforced at application level. For DB-level enforcement, add a CHECK constraint via migration:
  // ALTER TABLE "LinkClick" ADD CONSTRAINT "link_click_exclusive" 
  // CHECK (NUM_NULLS(socialLinkId, customLinkId) = 1);
  socialLinkId String?
  customLinkId String?

  // Visitor info
  visitorId    String?
  ipAddress    String?
  userAgent    String?
  deviceType   DeviceType @default(UNKNOWN)

  // Location
  city         String?
  country      String?
  countryCode  String?

  // Attribution
  referrer     String?
  utmSource    String?

  createdAt    DateTime   @default(now())

  // Relations
  card         Card       @relation(fields: [cardId], references: [id], onDelete: Cascade)
  socialLink   SocialLink? @relation(fields: [socialLinkId], references: [id], onDelete: SetNull)
  customLink   CustomLink? @relation(fields: [customLinkId], references: [id], onDelete: SetNull)

  @@index([cardId])
  @@index([socialLinkId])
  @@index([customLinkId])
  @@index([createdAt])
  @@index([visitorId])
}

// =============================================================================
// LEADS & CONTACT MANAGEMENT
// =============================================================================

model Lead {
  id                  String         @id @default(cuid())
  userId              String
  businessProfileId    String
  cardId              String?

  // Contact Information
  name                String
  firstName           String?
  lastName            String?
  email               String?
  phone               String?
  company             String?
  jobTitle            String?

  // Profile
  avatar              String?
  notes               String?        @db.Text
  tags                String[]

  // Source
  source              LeadSource
  sourceDetail        String?
  utmSource           String?
  utmCampaign         String?

  // Engagement
  engagementScore      Int            @default(0)
  interestLevel       Int            @default(0)

  // CRM Status
  status              LeadStatus     @default(NEW)
  isFavorite          Boolean        @default(false)
  isArchived          Boolean        @default(false)

  // Lead Score
  leadScore           Int            @default(0)

  // Consent
  marketingConsent    Boolean        @default(false)
  consentGivenAt      DateTime?
  gdprConsent         Boolean        @default(false)

  // Lead Value
  estimatedValue      Float?

  // Activity
  lastContactedAt     DateTime?
  lastEngagedAt       DateTime?
  interactionCount    Int            @default(0)

  // Timestamps
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  // Relations - Many-to-One
  user                User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessProfile     BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)
  card                Card?          @relation(fields: [cardId], references: [id], onDelete: SetNull)

  // Relations - One-to-Many
  interactions        LeadInteraction[]
  tasks               LeadTask[]
  activities          LeadActivity[]

  @@index([userId])
  @@index([businessProfileId])
  @@index([cardId])
  @@index([source])
  @@index([status])
  @@index([email])
  @@index([createdAt])
  @@index([engagementScore])
  @@index([isFavorite])
  @@index([isArchived])
  @@index([userId, status])
}

model LeadInteraction {
  id         String    @id @default(cuid())
  leadId     String

  type       String
  subject    String?
  body       String?   @db.Text
  direction  String?
  outcome    String?

  scheduledAt  DateTime?
  startedAt    DateTime?
  completedAt  DateTime?
  durationSeconds Int?

  metadata    Json?
  attachments Json?

  createdAt   DateTime  @default(now())

  lead        Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([type])
  @@index([createdAt])
}

model LeadTask {
  id          String       @id @default(cuid())
  leadId      String

  title       String
  description String?      @db.Text
  status      String       @default("pending")
  priority    TaskPriority @default(MEDIUM)

  dueDate     DateTime?
  startedAt   DateTime?
  completedAt DateTime?

  reminderAt    DateTime?
  reminderSent  Boolean     @default(false)

  assignedTo  String?

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  lead        Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([status])
  @@index([dueDate])
}

model LeadActivity {
  id        String      @id @default(cuid())
  leadId    String

  type      String
  title     String
  description String?
  metadata  Json?

  city      String?
  country   String?
  deviceType DeviceType?

  createdAt DateTime    @default(now())

  lead      Lead        @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([createdAt])
}

// =============================================================================
// BILLING & SUBSCRIPTIONS
// =============================================================================

model Order {
  id           String      @id @default(cuid())
  userId       String
  orderNumber  String      @unique

  items        Json
  subtotal     Float
  tax          Float       @default(0)
  taxRate      Float       @default(0)
  discount     Float       @default(0)
  discountCode String?
  shipping     Float       @default(0)
  total        Float
  currency     String      @default("USD")

  status       OrderStatus @default(PENDING)

  shippingName     String?
  shippingPhone    String?
  shippingAddress  Json?
  shippingMethod   String?
  shippingCost     Float?

  trackingNumber   String?
  trackingUrl      String?
  carrier          String?

  paymentMethodId  String?
  paymentIntentId  String?
  paidAt           DateTime?

  fulfilledAt     DateTime?
  shippedAt       DateTime?
  deliveredAt     DateTime?

  customerNotes   String?   @db.Text
  internalNotes   String?   @db.Text

  refundAmount    Float     @default(0)
  refundReason    String?
  refundedAt      DateTime?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderItems      OrderItem[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([userId, status])
}

model OrderItem {
  id         String  @id @default(cuid())
  orderId    String
  productId  String

  sku        String?
  name       String
  description String?
  quantity   Int
  unitPrice  Float
  total      Float
  options    Json?

  weight     Float?
  dimensions Json?

  order      Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([productId])
}

model Product {
  id        String   @id @default(cuid())

  name      String
  slug      String   @unique
  description String? @db.Text
  shortDescription String?

  price     Float
  compareAtPrice Float?
  costPrice Float?

  sku       String?  @unique
  barcode   String?
  inventory Int      @default(0)
  trackInventory Boolean @default(true)
  lowStockThreshold Int @default(10)

  weight    Float?
  dimensions Json?

  images    Json?
  thumbnailUrl String?

  category  String?
  tags      String[]

  status    String   @default("active")
  isDigital Boolean  @default(false)

  nfcChipType   String?
  cardMaterial  String?
  cardColors    Json?

  requiresShipping Boolean @default(true)
  freeShipping    Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orderItems OrderItem[]

  @@index([category])
  @@index([status])
  @@index([sku])
}

model Invoice {
  id           String        @id @default(cuid())
  userId       String
  invoiceNumber String       @unique

  subscriptionId String?

  periodStart DateTime
  periodEnd   DateTime

  items       Json

  subtotal    Float
  tax         Float         @default(0)
  taxRate     Float         @default(0)
  discount    Float         @default(0)
  total       Float
  currency    String        @default("USD")

  status      PaymentStatus @default(PENDING)
  paidAt      DateTime?
  dueDate     DateTime?

  stripeInvoiceId      String? @unique
  stripePaymentIntent  String?
  stripeSubscriptionId String?
  stripeChargeId       String?

  pdfUrl      String?
  notes       String?

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([userId, status])
}

model PaymentMethod {
  id                    String           @id @default(cuid())
  userId                String

  stripePaymentMethodId String           @unique

  brand                 PaymentCardBrand
  last4                 String
  expMonth              Int
  expYear               Int
  funding               String?

  displayName           String?
  isDefault             Boolean          @default(false)

  billingName           String?
  billingAddress        Json?

  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  user                  User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Plan {
  id         Int      @id @default(autoincrement())

  name       String   @unique
  tier       PlanTier @unique

  priceMonthly Float
  priceYearly  Float
  currency    String   @default("USD")

  maxCards     Int
  maxTaps      Int
  maxStorageMb Int
  maxLeads     Int
  maxTeamMembers Int @default(1)

  features    String[]

  description String?
  popular     Boolean  @default(false)

  trialDays   Int      @default(0)

  isActive     Boolean @default(true)
  displayOrder Int     @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// =============================================================================
// GOALS & TARGETS
// =============================================================================

model Goal {
  id          String    @id @default(cuid())
  userId      String

  name        String
  type        GoalType

  targetValue Int
  currentValue Int      @default(0)

  period      String
  startDate   DateTime
  endDate     DateTime

  status      String    @default("active")
  progress    Float     @default(0)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([status])
  @@index([startDate, endDate])
}

// =============================================================================
// NOTIFICATIONS
// =============================================================================

model Notification {
  id      String           @id @default(cuid())
  userId  String
  type    NotificationType

  title   String
  message String
  data    Json?

  read    Boolean         @default(false)
  readAt  DateTime?

  actionUrl   String?
  actionLabel String?

  emailSent   Boolean @default(false)
  emailSentAt DateTime?
  pushSent    Boolean @default(false)
  pushSentAt  DateTime?

  priority  String @default("normal")

  sourceId   String?
  sourceType String?

  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([read])
  @@index([type])
  @@index([createdAt])
}

// =============================================================================
// CONNECTED ACCOUNTS
// =============================================================================

model UserConnectedAccount {
  id       String   @id @default(cuid())
  userId   String

  platform String

  connected    Boolean  @default(false)
  connectedAt  DateTime?

  accountId    String?
  accountName  String?
  accountUrl   String?
  accountAvatar String?

  accessToken  String?
  refreshToken String?
  expiresAt    DateTime?

  scopes       String[]

  lastSyncedAt  DateTime?
  syncStatus    String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platform])
  @@index([userId])
}

// =============================================================================
// NFC CARDS (Physical)
// =============================================================================

model NfcCard {
  id        Int      @id @default(autoincrement())
  cardId    String?  @unique
  userId    String?

  // NFC Chip - UNIQUE uid constraint
  uid       String   @unique
  chipType  String?
  ndefCapacity Int?

  // Physical Card
  physicalCardId String? @unique
  cardMaterial   String?
  cardColors     Json?
  cardWeight     Float?

  assignedAt     DateTime?

  // Status
  isActivated    Boolean @default(false)
  isLinked       Boolean @default(false)
  isAssigned     Boolean @default(false)
  activationCode String?

  // Usage
  writeCount     Int     @default(0)
  lastWrittenAt  DateTime?
  lastTapAt      DateTime?
  totalTaps      Int     @default(0)

  // Product
  productId      String?
  sku            String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  user           User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  card           Card?    @relation(fields: [cardId], references: [id], onDelete: SetNull)

  @@index([uid])
  @@index([userId])
  @@index([isActivated])
}

// =============================================================================
// ANALYTICS EVENTS
// =============================================================================

model AnalyticsEvent {
  id       String     @id @default(cuid())
  userId   String?
  cardId   String?

  eventName      String
  eventCategory  String

  properties     Json?

  sessionId      String?
  pageUrl        String?
  pageName       String?
  pageTitle      String?
  referrer       String?

  deviceType     DeviceType @default(UNKNOWN)
  browser        String?
  browserVersion String?
  os             String?
  osVersion      String?
  screenWidth    Int?
  screenHeight   Int?
  isMobile       Boolean?

  ipCountry      String?
  ipCity         String?
  ipRegion       String?

  utmSource      String?
  utmMedium      String?
  utmCampaign    String?
  utmTerm        String?
  utmContent     String?

  createdAt      DateTime @default(now())

  user           User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([cardId])
  @@index([eventName])
  @@index([eventCategory])
  @@index([createdAt])
}

// =============================================================================
// DASHBOARD STATISTICS (One-to-One with User)
// =============================================================================

model DashboardStats {
  id       String @id @default(cuid())
  userId   String @unique

  // Period Stats
  todayTaps Int @default(0)
  todayViews Int @default(0)
  todayLeads Int @default(0)

  weekTaps  Int @default(0)
  weekViews Int @default(0)
  weekLeads Int @default(0)

  monthTaps  Int @default(0)
  monthViews Int @default(0)
  monthLeads Int @default(0)

  // Trends
  tapsTrend  Float @default(0)
  viewsTrend Float @default(0)
  leadsTrend Float @default(0)

  // Conversion
  conversionRate Float @default(0)

  // Top Card
  topCardId   String?
  topCardName String?
  topCardTaps Int     @default(0)

  updatedAt   DateTime @default(now())

  // One-to-One with User (enforced by unique userId)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// =============================================================================
// AUDIT LOG
// =============================================================================

model AuditLog {
  id         String      @id @default(cuid())
  userId     String?

  action     AuditAction
  entityType String
  entityId   String?

  description String?
  changes    Json?

  ipAddress  String?
  userAgent  String?
  sessionId  String?
  deviceType DeviceType?

  metadata   Json?

  createdAt  DateTime    @default(now())

  user       User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([entityType, entityId])
  @@index([action])
  @@index([createdAt])
}

// =============================================================================
// EMAIL & NOTIFICATIONS TEMPLATES
// =============================================================================

model EmailTemplate {
  id        Int     @id @default(autoincrement())

  name      String  @unique
  slug      String  @unique

  subject   String
  body      String  @db.Text
  preheader String?

  type      String
  trigger   String?

  variables String[]

  isActive  Boolean @default(true)
  isSystem  Boolean @default(false)

  version   Int     @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// =============================================================================
// WEBHOOKS (Integrations)
// =============================================================================

model Webhook {
  id       String   @id @default(cuid())
  userId   String?

  name     String
  url      String
  secret   String?

  events   String[]
  headers  Json?

  isActive Boolean @default(true)

  maxRetries Int   @default(3)
  retryCount Int   @default(0)

  lastTriggeredAt DateTime?
  lastSuccessAt   DateTime?
  lastError       String?
  lastResponseCode Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  deliveries WebhookDelivery[]

  @@index([userId])
}

model WebhookDelivery {
  id          String   @id @default(cuid())
  webhookId   String

  event       String
  payload     Json
  responseCode Int?
  responseBody String?
  error       String?

  attempts    Int      @default(1)
  delivered   Boolean @default(false)

  createdAt   DateTime @default(now())

  webhook     Webhook  @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId])
}
